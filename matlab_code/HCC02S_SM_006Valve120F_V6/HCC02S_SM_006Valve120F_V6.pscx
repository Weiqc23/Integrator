        <port model="Transfer" name="Level" x="54" y="0" dim="1" mode="Output" type="Integer" internal="false"><![CDATA[true]]></port>
        <port model="Transfer" name="OffPulse" x="-54" y="18" dim="1" mode="Input" type="Integer" internal="false"><![CDATA[true]]></port>
        <port model="Transfer" name="OnPulse" x="-54" y="-18" dim="1" mode="Input" type="Integer" internal="false"><![CDATA[true]]></port>
        <cond><![CDATA[true]]></cond>
        <rect x="-39" y="-32" width="78" height="64" stroke="black" stroke-width="0.2" stroke-dasharray="none" fill-style="Hollow" fill-fg="black" fill-bg="black" />
        <line x1="-54" y1="-18" x2="-39" y2="-18" stroke="Black" stroke-width="0.2" stroke-dasharray="none" port="" />
        <text x="-14" y="-15" stroke="Black" font-size="Small" text-anchor="Middle"><![CDATA[OnPulse]]></text>
        <line x1="-44" y1="-23" x2="-39" y2="-18" stroke="Black" stroke-width="0.2" stroke-dasharray="none" port="" />
        <line x1="-44" y1="-13" x2="-39" y2="-18" stroke="Black" stroke-width="0.2" stroke-dasharray="none" port="" />
        <line x1="-54" y1="18" x2="-39" y2="18" stroke="Black" stroke-width="0.2" stroke-dasharray="none" port="" />
        <text x="-12" y="20" stroke="Black" font-size="Small" text-anchor="Middle"><![CDATA[OffPulse]]></text>
        <line x1="-44" y1="13" x2="-39" y2="18" stroke="Black" stroke-width="0.2" stroke-dasharray="none" port="" />
        <line x1="-44" y1="23" x2="-39" y2="18" stroke="Black" stroke-width="0.2" stroke-dasharray="none" port="" />
        <line x1="54" y1="0" x2="39" y2="0" stroke="Black" stroke-width="0.2" stroke-dasharray="none" port="" />
        <text x="23" y="3" stroke="black" font-size="small" text-anchor="Middle"><![CDATA[Level]]></text>
      </svg>
      <script>
        <segment name="Fortran"><![CDATA[      IF(TIMEZERO)THEN
        $Level=0
      ELSE
        IF($OnPulse.EQ.1)THEN
          $Level=1
        ELSE
          IF($OffPulse.EQ.1)THEN
            $Level=0
          ENDIF
        ENDIF
      ENDIF]]></segment>
        <segment name="Branch"><![CDATA[]]></segment>
        <segment name="Computations"><![CDATA[]]></segment>
      </script>
    </Definition>
