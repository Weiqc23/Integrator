    <Definition classid="UserCmpDefn" name="Electrical_SaturableReactor" group="" url="" version="" build="" crc="78267909" instances="0" key="" view="false" date="0" id="1141181911">
      <paramlist name="">
        <param name="Description" value="" />
      </paramlist>
      <form name="" w="320" h="400" splitter="60">
        <category name="Configuration" visible="true">
          <cond />
          <parameter desc="Lair" name="Lair" group="" unit="H" min="0" max="" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[6.3 [uH]]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Cs" name="Cs" group="" unit="uF" min="0" max="" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[250 [pF]]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Lm_const" name="Lm_const" group="" unit="H" min="0" max="" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[0.57 [mH]]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Lm_saturation factor" name="Lm_satFactor" group="" unit="kA" min="0" max="" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[80 [A]]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Re_const" name="Re_const" group="General" unit="ohm" min="0" max="" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[250 [ohm]]]></value>
            <cond />
            <help />
          </parameter>
          <parameter desc="Re_saturation factor" name="Re_satFactor" group="General" unit="kA" min="0" max="" content_type="Constant" type="Real" helpmode="Append" intent="Input" dim="1">
            <value><![CDATA[30 [A]]]></value>
            <cond />
            <help />
          </parameter>
        </category>
      </form>
      <svg viewBox="-200 -200 200 200" size="4">
        <port model="Natural" name="A" x="-18" y="0" dim="0" mode="Electrical" type="Removable" internal="false"><![CDATA[true]]></port>
        <port model="Natural" name="B" x="18" y="0" dim="0" mode="Electrical" type="Removable" internal="false"><![CDATA[true]]></port>
        <port model="Natural" name="C" x="0" y="0" dim="1" mode="Electrical" type="NonRemovable" internal="false"><![CDATA[true]]></port>
        <cond><![CDATA[true]]></cond>
        <line x1="13" y1="0" x2="18" y2="0" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="A" />
        <path d="M12.000 0.000 A4 4 0 1 1 4.000 -0.000" arc="4,-4,13,4,0,-180" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="A" />
        <path d="M4.000 0.000 A4 4 0 1 1 -4.000 -0.000" arc="-5,-4,4,4,0,-180" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="A" />
        <path d="M-5.000 0.000 A4 4 0 1 1 -13.000 -0.000" arc="-14,-4,-5,4,0,-180" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="A" />
        <line x1="-18" y1="0" x2="-14" y2="0" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="A" />
        <line x1="13" y1="0" x2="18" y2="0" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="B" />
        <path d="M12.000 0.000 A4 4 0 1 1 4.000 -0.000" arc="4,-4,13,4,0,-180" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="B" />
        <path d="M4.000 0.000 A4 4 0 1 1 -4.000 -0.000" arc="-5,-4,4,4,0,-180" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="B" />
        <path d="M-5.000 0.000 A4 4 0 1 1 -13.000 -0.000" arc="-14,-4,-5,4,0,-180" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="B" />
        <line x1="-18" y1="0" x2="-14" y2="0" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="B" />
        <line x1="13" y1="0" x2="18" y2="0" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="A" />
        <path d="M12.000 0.000 A4 4 0 1 1 4.000 -0.000" arc="4,-4,13,4,0,-180" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="A" />
        <path d="M4.000 0.000 A4 4 0 1 1 -4.000 -0.000" arc="-5,-4,4,4,0,-180" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="A" />
        <path d="M-5.000 0.000 A4 4 0 1 1 -13.000 -0.000" arc="-14,-4,-5,4,0,-180" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="A" />
        <line x1="-18" y1="0" x2="-14" y2="0" stroke="Black" stroke-dasharray="none" stroke-width="ByNode" port="A" />
        <line x1="7" y1="-11" x2="-7" y2="10" stroke="Black" stroke-dasharray="none" stroke-width="0.2" port="" />
        <path d="M14.733 -13.967 A14 24 0 0 0 6.375 -10.128" arc="0,-14,29,35,87,36" stroke="Black" stroke-dasharray="none" stroke-width="0.2" port="" />
        <path d="M-15.785 13.967 A15 24 0 0 0 -6.830 10.128" arc="-30,-35,0,14,-93,36" stroke="Black" stroke-dasharray="none" stroke-width="0.2" port="" />
      </svg>
      <script>
        <segment name="Branch"><![CDATA[ BRCS = $A $B 0.0 0.0 $Cs
 BRLair = $A $C 0.0 $Lair 0.0
 BRLm= $C $B BREAKER 1.0
 BRRe= $C $B BREAKER 1.0]]></segment>
        <segment name="Dsdyn"><![CDATA[#BEGIN
      CALL E_VARRLC1_CFG(1,$SS,$BRLm,0)
      CALL E_VARRLC1_CFG(0,$SS,$BRRe,0)
#ENDBEGIN

#LOCAL REAL Im
#LOCAL REAL Lm
#LOCAL REAL Re

      Im = CBR($BRLm,$SS)
      IF (Im .lt. 0.0) THEN
        Im=-Im
      ENDIF

      IF (Im .lt. $Lm_satFactor) THEN
        Lm = $Lm_const
      Else
        Lm = $Lm_const * $Lm_satFactor / Im
      ENDIF

      IF (Im .lt. $Re_satFactor) THEN
        Re = $Re_const
      Else
        Re = $Re_const * $Re_satFactor / Im
      ENDIF

      CALL E_VARRLC1_EXE(1 ,$SS , $BRLm, 0, Lm , 0.0)
      CALL E_VARRLC1_EXE(0 ,$SS , $BRRe, 0, Re , 0.0)]]></segment>
      </script>
    </Definition>
